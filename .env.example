# Primary sending domain (first entry in domains.conf — Postfix HELO identity)
MAIL_DOMAIN=example.com
MAIL_HOSTNAME=smtp.mail.example.com

# Default DKIM selector (per-domain overrides in domains.conf)
DKIM_SELECTOR=mail

# Where Postfix listens (host:container). Examples:
#   127.0.0.1:25:25       localhost only (dev)
#   <internal-ip>:25:25   host internal IP (production — apps use same IP as SMTP_HOST)
SMTP_BIND=127.0.0.1:25:25

# Networks allowed to relay without auth (docker + private CIDRs)
SMTP_RELAY_MYNETWORKS="127.0.0.0/8 172.16.0.0/12 172.20.0.0/16 10.0.0.0/8"

# Optional: attach mailer to an existing docker network
# DOCKER_NETWORK=my-app-network

# App SMTP settings — SMTP_HOST must match the IP in SMTP_BIND
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=My App
